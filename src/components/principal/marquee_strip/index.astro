---
import { marqueeItems } from "@config";

const line = marqueeItems.join(" ● ");
---

<div
  class="overflow-hidden border-y-[1.5px] border-ink bg-orange py-4 text-paper"
>
  <div
    class="flex w-max animate-[brand-marquee_28s_linear_infinite] gap-10 font-display text-xl font-semibold uppercase tracking-normal md:text-2xl"
  >
    <span class="whitespace-nowrap">● {line} ●</span>
    <span class="whitespace-nowrap">● {line} ●</span>
    <span class="whitespace-nowrap">● {line} ●</span>
    <span class="whitespace-nowrap">● {line} ●</span>
  </div>
</div>

<style>
  @keyframes brand-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
