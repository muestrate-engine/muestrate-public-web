---
import { teamMembers } from "@config";
import { SectionHeading } from "@components/shared";
---

<section
  id="equipo"
  class="border-y-[1.5px] border-ink bg-paper py-24 md:py-32"
>
  <div class="container-shell">
    <SectionHeading
      eyebrow="05 / Nuestro equipo"
      description="Cuatro personas que saben lo que hacen. Sin intermediarios, sin juniors. Atiendes con el que diseña tu web."
    >
      <Fragment slot="title"
        >Un equipo chico,<br />con <span class="text-orange">mano gruesa.</span
        ></Fragment
      >
    </SectionHeading>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        teamMembers.map((person) => (
          <article class="sticker-lift brand-outline overflow-hidden rounded-brand-lg bg-paper-warm">
            <div class="relative aspect-square overflow-hidden border-b-[1.5px] border-ink">
              {person.imageUrl ? (
                <img
                  src={person.imageUrl}
                  alt={person.name}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div
                  class={`grid h-full w-full place-items-center font-display text-[7rem] font-bold leading-none tracking-normal ${person.colorClass}`}
                >
                  {person.initials}
                </div>
              )}
              <span
                class={`pointer-events-none absolute right-4 top-4 z-10 text-4xl ${
                  person.sparkle === "dark" ? "text-ink" : "text-paper"
                }`}
                aria-hidden="true"
              >
                ✦
              </span>
            </div>
            <div class="p-5">
              <h3 class="font-display text-xl font-semibold tracking-normal">
                {person.name}
              </h3>
              <p class="mt-1 text-xs font-bold uppercase tracking-[0.04em] text-orange">
                {person.role}
              </p>
              <p class="mt-3 text-sm leading-6 text-gray-700">{person.bio}</p>
              <div class="mt-4 flex gap-2">
                <a
                  href="#"
                  class="focus-ring grid size-8 place-items-center rounded-full bg-ink text-xs font-bold! text-paper!"
                >
                  in
                </a>
                <a
                  href="#"
                  class="focus-ring grid size-8 place-items-center rounded-full bg-ink text-xs font-bold! text-paper!"
                >
                  @
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
