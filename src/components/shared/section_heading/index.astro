---
interface Props {
  eyebrow: string;
  description?: string;
  light?: boolean;
  centered?: boolean;
  eyebrowClass?: string;
}

const {
  eyebrow,
  description,
  light = false,
  centered = false,
  eyebrowClass = "",
} = Astro.props;
---

<div
  class:list={[
    "mb-12 max-w-4xl md:mb-16",
    centered && "mx-auto text-center",
  ]}
>
  <div
    class:list={[
      "mb-4 font-display text-sm font-semibold uppercase tracking-[0.1em]",
      light ? "text-orange-300" : "text-orange",
      eyebrowClass,
    ]}
  >
    {eyebrow}
  </div>
  <h2
    class:list={[
      "font-display text-[clamp(2.75rem,6vw,5rem)] font-semibold leading-[0.96] tracking-normal",
      light ? "text-paper" : "text-ink",
    ]}
  >
    <slot name="title" />
  </h2>
  {
    description && (
      <p
        class:list={[
          "mt-5 max-w-2xl text-lg leading-8 md:text-xl",
          centered && "mx-auto",
          light ? "text-gray-300" : "text-gray-700",
        ]}
      >
        {description}
      </p>
    )
  }
</div>
