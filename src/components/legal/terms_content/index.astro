---
import { CONTACT_EMAIL, termsSections, WHATSAPP_URL } from "@config";
import { ButtonLink } from "@components/shared";
---

<main class="bg-paper-warm">
  <section class="border-b-[1.5px] border-ink bg-ink py-20 text-paper md:py-28">
    <div class="container-shell">
      <p class="mb-6 inline-flex rounded-full border border-paper/15 bg-paper/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.06em]">
        Legal · Términos
      </p>
      <h1 class="max-w-5xl font-display text-[clamp(3.5rem,9vw,7.5rem)] font-semibold leading-[0.9] tracking-normal">
        Reglas claras,<br /><span class="text-orange">proyectos tranquilos.</span>
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-gray-300">
        Estos términos explican cómo trabajamos, qué esperamos del cliente y qué puedes esperar de Muéstrate cuando contratas un servicio.
      </p>
      <p class="mt-6 text-sm font-semibold text-paper/70">Última actualización: 25 de abril de 2026</p>
    </div>
  </section>

  <section class="py-20 md:py-28">
    <div class="container-shell grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
      <aside class="lg:sticky lg:top-28 lg:self-start">
        <div class="brand-outline rounded-brand-lg bg-paper p-6">
          <h2 class="font-display text-2xl font-semibold tracking-normal">Resumen corto</h2>
          <p class="mt-4 text-sm leading-7 text-gray-700">
            Trabajamos con propuestas claras, pagos acordados, entregables definidos y revisiones ordenadas. Si algo cambia, se conversa y se cotiza antes de hacerlo.
          </p>
          <div class="mt-6 grid gap-3">
            <ButtonLink href={WHATSAPP_URL} target="_blank" rel="noreferrer" class="w-full">Resolver una duda</ButtonLink>
            <ButtonLink href={`mailto:${CONTACT_EMAIL}`} variant="ghost" class="w-full">Escribir por correo</ButtonLink>
          </div>
        </div>
      </aside>

      <div class="space-y-5">
        {
          termsSections.map((section) => (
            <article id={section.id} class="brand-outline scroll-mt-28 rounded-brand-lg bg-paper p-7 md:p-9">
              <h2 class="font-display text-3xl font-semibold tracking-normal">{section.title}</h2>
              <div class="mt-5 space-y-4 text-base leading-8 text-gray-700">
                {section.body.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</main>
