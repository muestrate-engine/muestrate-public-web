---
const steps = [
  {
    title: "Primero entendemos qué vendes.",
    text: "No empezamos por colores ni plantillas. Empezamos por saber qué servicio quieres vender, a quién y por qué te eligen.",
  },
  {
    title: "Luego lo convertimos en una web clara.",
    text: "Fotos, mensajes, secciones, WhatsApp y Google Maps trabajan juntos para que el cliente sepa qué hacer.",
  },
  {
    title: "Finalmente medimos lo que importa.",
    text: "Llamadas, formularios, mensajes y reservas. Likes bonitos ayudan, pero clientes nuevos pagan la cuenta.",
  },
];
---

<section class="border-y-[1.5px] border-ink bg-paper py-24 md:py-32">
  <div class="container-shell">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.1em] text-orange">Cómo llegamos ahí</p>
        <h2 class="font-display text-[clamp(2.75rem,6vw,4.75rem)] font-semibold leading-none tracking-normal">
          No es magia.<br />Es ordenar lo que ya haces bien.
        </h2>
      </div>
      <div class="grid gap-4">
        {
          steps.map((step, index) => (
            <article class="brand-outline rounded-brand-lg bg-paper-warm p-7">
              <div class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.1em] text-orange">
                0{index + 1}
              </div>
              <h3 class="font-display text-2xl font-semibold tracking-normal">{step.title}</h3>
              <p class="mt-3 leading-7 text-gray-700">{step.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
