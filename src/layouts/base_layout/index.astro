---
import "@styles/global.css";
import { FloatingActions } from "@components/shared";
import {
  type PageMeta,
  BRAND_NAME,
  DEFAULT_IMAGE,
  HREFLANG,
  LOCALE,
  OG_IMAGE_HEIGHT,
  OG_IMAGE_WIDTH,
  getDefaultPageStructuredData,
  makeCanonicalUrl,
  ROUTES,
  TWITTER_HANDLE,
} from "@config";

interface Props {
  meta: PageMeta;
  /**
   * JSON-LD adicional (p. ej. ofertas o FAQ en el futuro). El layout ya incluye
   * organización, WebSite en inicio, WebPage y miga de pan.
   */
  extraStructuredData?: unknown | unknown[];
  bodyClass?: string;
  /** Fuerza noindex; también se usa meta.noindex */
  noindex?: boolean;
}

const { meta, extraStructuredData, bodyClass = "", noindex: noindexProp = false } =
  Astro.props;
const noindex = noindexProp || meta.noindex;
const canonicalUrl = makeCanonicalUrl(meta.path);
const imagePath = meta.image ?? DEFAULT_IMAGE;
const imageUrl = makeCanonicalUrl(imagePath);
const isRootImage = imagePath === DEFAULT_IMAGE;
const isHome = meta.path === ROUTES.home;
const defaultLd = getDefaultPageStructuredData(meta, { isHome });
const extra = Array.isArray(extraStructuredData)
  ? extraStructuredData
  : extraStructuredData
    ? [extraStructuredData]
    : [];
const schemas = [...defaultLd, ...extra];
const keywords =
  meta.keywords?.filter(Boolean).join(", ") ||
  "marketing digital, diseño web, MYPEs, Perú, Huancayo, branding, Muéstrate";
const ogType = meta.ogType ?? "website";
const imageAlt = meta.imageAlt || meta.title;
const docLang = "es-PE" as const;
---

<!doctype html>
<html lang="es" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta name="language" content={docLang} />
    <meta
      name="robots"
      content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta
      name="googlebot"
      content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />
    <meta name="author" content={BRAND_NAME} />
    <meta name="geo.region" content="PE-JUN" />
    <meta name="geo.placename" content="Huancayo" />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={HREFLANG} href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/assets/isotipo-m.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <meta name="theme-color" content="#FF5B1F" />

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={LOCALE} />
    <meta property="og:site_name" content={BRAND_NAME} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    {!isRootImage && <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />}
    {!isRootImage && <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />}
    {
      isRootImage && (
        <>
          <meta property="og:image:type" content="image/svg+xml" />
        </>
      )
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={imageUrl} />
    {TWITTER_HANDLE && <meta name="twitter:site" content={`@${TWITTER_HANDLE}`} />}
    {TWITTER_HANDLE && <meta name="twitter:creator" content={`@${TWITTER_HANDLE}`} />}

    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class={bodyClass}>
    <slot />
    <FloatingActions />
    <script>
      import "../../scripts/site_animations";
    </script>
  </body>
</html>