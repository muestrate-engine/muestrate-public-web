---
import { brandWords, voiceExamples } from "@config";
---

<section id="voice" class="border-t-[1.5px] border-ink bg-paper-warm py-20 md:py-24">
  <div class="container-shell">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="font-display text-lg font-semibold uppercase tracking-[0.1em] text-orange">05 / Voz y tono</p>
        <h2 class="mt-2 font-display text-[clamp(2.5rem,5vw,4rem)] font-semibold leading-none tracking-normal">Cercano pero<br />profesional.</h2>
      </div>
      <p class="max-w-md leading-7 text-gray-700">
        Hablamos como Yape, pero a negocios. Tuteo directo, frases cortas, un toque de humor peruano. <strong>Nunca formal,</strong> nunca con jerga técnica que nadie entiende.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <article class="brand-outline rounded-brand-lg bg-paper p-7">
        <span class="inline-flex rounded-full bg-success px-3 py-1 text-xs font-bold uppercase tracking-[0.08em] text-paper">Sí</span>
        <div class="mt-4 space-y-2">
          {voiceExamples.do.map((example) => <p class="font-display text-xl font-medium leading-snug tracking-normal">"{example}"</p>)}
        </div>
        <p class="mt-5 text-sm leading-6 text-gray-500">Frases cortas. Tuteo. Beneficio concreto. Un poquito de chispa.</p>
      </article>

      <article class="brand-outline rounded-brand-lg bg-gray-50 p-7">
        <span class="inline-flex rounded-full bg-ink px-3 py-1 text-xs font-bold uppercase tracking-[0.08em] text-paper">No</span>
        <div class="mt-4 space-y-2">
          {voiceExamples.dont.map((example) => <p class="font-display text-xl font-medium leading-snug tracking-normal opacity-70 line-through">"{example}"</p>)}
        </div>
        <p class="mt-5 text-sm leading-6 text-gray-500">Lenguaje corporativo aburrido. Usted. Jerga vacía.</p>
      </article>
    </div>

    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {
        brandWords.map((word) => (
          <article class="brand-outline rounded-brand-lg bg-paper p-6 shadow-pop">
            <div class="font-display text-sm font-semibold uppercase tracking-[0.06em] text-orange">{word.label}</div>
            <div class="mt-1 font-display text-3xl font-semibold tracking-normal">{word.value}</div>
          </article>
        ))
      }
    </div>
  </div>
</section>
