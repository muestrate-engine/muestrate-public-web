---
import { BaseLayout } from "@layouts";
import {
  AssetsSection,
  BrandSection,
  ColorSection,
  ComponentsSection,
  DesignFooter,
  DesignHeader,
  DesignHero,
  TypographySection,
  VoiceSection,
} from "@components";
import { PAGE_META } from "@config";
---

<BaseLayout meta={PAGE_META.design}>
  <DesignHeader />
  <main>
    <DesignHero />
    <BrandSection />
    <ColorSection />
    <TypographySection />
    <ComponentsSection />
    <VoiceSection />
    <AssetsSection />
  </main>
  <DesignFooter />
</BaseLayout>
