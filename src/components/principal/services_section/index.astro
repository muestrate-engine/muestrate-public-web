---
import { services } from "@config";
import { SectionHeading } from "@components/shared";
---

<section id="servicios" class="bg-ink py-24 text-paper md:py-32">
  <div class="container-shell">
    <SectionHeading
      eyebrow="03 / Nuestros servicios"
      description="Webs, marca, redes, y campañas que traen clientes reales — no likes vacíos."
      light
    >
      <Fragment slot="title">Todo lo que<br />tu negocio <span class="text-orange">necesita</span> online.</Fragment>
    </SectionHeading>

    <div class="grid gap-5 lg:grid-cols-[1.3fr_1fr_1fr]">
      {
        services.map((service) => (
          <a
            href={service.href}
            target="_blank"
            rel="noopener noreferrer"
            class={`group flex min-h-80 flex-col justify-between overflow-hidden rounded-brand-lg border-[1.5px] p-8 transition ${
              service.featured
                ? "border-orange bg-orange text-paper lg:row-span-2 lg:min-h-164 hover:border-orange-600 hover:bg-orange-600"
                : "border-paper/15 bg-paper/5 hover:border-orange hover:bg-orange/10"
            }`}
          >
            <div>
              <div
                class={`font-display text-xs font-semibold tracking-widest ${service.featured ? "text-paper/80" : "text-orange"}`}
              >
                {service.number}
              </div>
              <h3
                class={`mt-4 font-display font-semibold! leading-none tracking-normal ${service.featured ? "text-5xl" : "text-3xl"}`}
              >
                {service.title}
              </h3>
              <p
                class={`mt-3 leading-6 ${service.featured ? "text-base text-paper/90" : "text-sm text-gray-300"}`}
              >
                {service.text}
              </p>
              {
                "tags" in service && service.tags && (
                  <div class="mt-4 flex flex-wrap gap-2">
                    {service.tags.map((tag) => (
                      <span class="rounded-full bg-ink/20 px-3 py-1 text-[0.68rem] font-bold uppercase tracking-[0.06em] text-paper">
                        {tag}
                      </span>
                    ))}
                  </div>
                )
              }
            </div>

            <div class="mt-8">
              {"price" in service && service.price && <span class="inline-flex rounded-full bg-ink px-4 py-2 font-display text-sm font-semibold">{service.price}</span>}
              <div class="mt-5 flex items-center justify-between">
                <span class="font-display text-lg font-semibold">Empezar →</span>
                <span class="grid size-12 place-items-center rounded-full bg-paper text-xl font-bold text-ink transition group-hover:translate-x-1">→</span>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
