---
import { ROUTES } from "@config";

interface Props {
  label: string;
  title: string;
  description: string;
}

const { label, title, description } = Astro.props;
---

<section class="bg-paper-warm py-16 md:py-20">
  <div class="container-shell">
    <a href={ROUTES.design} class="focus-ring mb-7 inline-flex rounded-full text-sm font-bold text-ink hover:text-orange">
      ← Volver al sistema
    </a>
    <p class="mb-3 font-display text-sm font-semibold uppercase tracking-[0.1em] text-orange">{label}</p>
    <h1 class="font-display text-[clamp(3rem,7vw,5.5rem)] font-semibold leading-none tracking-normal">{title}</h1>
    <p class="mt-5 max-w-3xl text-base leading-8 text-gray-700 md:text-lg">{description}</p>
  </div>
</section>
