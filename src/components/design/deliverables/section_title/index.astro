---
interface Props {
  title: string;
  meta?: string;
}

const { title, meta } = Astro.props;
---

<div class="mb-5 mt-12 flex flex-wrap items-center gap-3">
  <span class="size-2.5 rounded-full bg-orange"></span>
  <h2 class="font-display text-2xl font-semibold tracking-normal">{title}</h2>
  {meta && <span class="ml-auto text-xs font-bold uppercase tracking-[0.08em] text-gray-500">{meta}</span>}
</div>
