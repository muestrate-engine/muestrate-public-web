---
import { WHATSAPP_URL } from "@config";

/** Misma base que button_link: borde, redondeo, transición del “lift”. */
const fabBase =
  "focus-ring inline-flex size-12 shrink-0 items-center justify-center rounded-full border-[1.5px] font-display font-semibold tracking-normal shadow-none duration-200 ease-out transition-[transform,box-shadow,opacity] hover:-translate-x-[3px] hover:-translate-y-[3px] md:size-14";

const fabPrimary =
  "border-orange bg-orange text-paper hover:shadow-[5px_5px_0_var(--m-paper)]";

const fabLight =
  "border-ink bg-paper text-ink hover:shadow-[5px_5px_0_var(--m-orange)]";
---

<div
  data-floating-actions
  class="fab-root fixed bottom-5 right-5 z-[60] md:bottom-6 md:right-6"
  aria-label="Acciones rápidas"
>
  <a
    href={WHATSAPP_URL}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[fabBase, fabPrimary]}
    aria-label="Hablar por WhatsApp"
    title="WhatsApp"
  >
    <svg viewBox="0 0 24 24" class="size-6" fill="currentColor" aria-hidden="true">
      <path
        d="M12 2C6.48 2 2 6.48 2 12c0 1.77.46 3.44 1.27 4.89L2 22l5.25-1.27A9.94 9.94 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2Zm5.25 14.19c-.21.59-1.23 1.12-1.72 1.17-.44.04-.99.06-1.59-.1-.37-.12-.84-.27-1.44-.53-2.54-1.1-4.2-3.66-4.33-3.83-.12-.17-1.04-1.38-1.04-2.64 0-1.25.66-1.87.89-2.13.23-.25.5-.31.67-.31h.48c.15 0 .35-.06.55.42.21.49.71 1.69.77 1.81.06.12.1.27.02.43-.08.17-.12.27-.23.42-.12.15-.25.33-.36.44-.12.12-.24.25-.1.49s.6 1.02 1.3 1.64c.89.8 1.64 1.04 1.88 1.16.25.12.39.1.53-.06.15-.17.62-.73.78-.98.17-.25.33-.21.55-.12.23.08 1.44.68 1.69.8.25.12.41.18.47.28.06.1.06.59-.15 1.18Z"
      ></path>
    </svg>
  </a>

  <div class="fab-scroll-slot">
    <button
      type="button"
      data-scroll-top
      class:list={[fabBase, fabLight]}
      aria-label="Volver arriba"
      title="Volver arriba"
    >
      <svg
        viewBox="0 0 24 24"
        class="size-6"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>
  </div>
</div>

<style>
  /* No usar variants group-data-* de Tailwind: no se generaban en el CSS (cero reglas en dist). */
  .fab-root {
    display: flex;
    flex-direction: column-reverse;
    align-items: flex-end;
    gap: 0;
    transition: gap 200ms ease-out;
  }

  .fab-root[data-scroll-shown="true"] {
    gap: 0.75rem;
  }

  .fab-scroll-slot {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      max-height 200ms ease-out,
      opacity 200ms ease-out;
  }

  .fab-root[data-scroll-shown="true"] .fab-scroll-slot {
    max-height: 4.5rem;
    opacity: 1;
    pointer-events: auto;
  }
</style>

<script>
  let teardown: (() => void) | null = null;

  const initFloatingActions = () => {
    teardown?.();
    teardown = null;

    const root = document.querySelector<HTMLElement>("[data-floating-actions]");
    const button = root?.querySelector<HTMLButtonElement>("[data-scroll-top]");
    if (!root || !button) return;

    const update = () => {
      const isVisible = window.scrollY > 420;
      if (isVisible) {
        root.setAttribute("data-scroll-shown", "true");
      } else {
        root.removeAttribute("data-scroll-shown");
      }
    };

    const onClick = () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    };

    window.addEventListener("scroll", update, { passive: true });
    button.addEventListener("click", onClick);
    update();

    teardown = () => {
      window.removeEventListener("scroll", update);
      button.removeEventListener("click", onClick);
    };
  };

  document.addEventListener("astro:page-load", initFloatingActions);
  document.addEventListener("astro:before-swap", () => teardown?.());
</script>
