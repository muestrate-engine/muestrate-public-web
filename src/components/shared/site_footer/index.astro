---
import {
  BRAND_NAME,
  BUSINESS_HOURS,
  BUSINESS_LOCATION,
  CONTACT_EMAIL,
  CONTACT_PHONE,
  CURRENT_YEAR,
  FOOTER_NAVIGATION,
  LEGAL_NAME,
  SOCIAL_LINKS,
  WHATSAPP_URL,
} from "@config";
import Logo from "../logo/index.astro";

const socialItems = [
  {
    label: "Instagram",
    href: SOCIAL_LINKS.instagram,
    viewBox: "0 0 24 24",
    path: "M7.75 2h8.5A5.76 5.76 0 0 1 22 7.75v8.5A5.76 5.76 0 0 1 16.25 22h-8.5A5.76 5.76 0 0 1 2 16.25v-8.5A5.76 5.76 0 0 1 7.75 2Zm0 2A3.75 3.75 0 0 0 4 7.75v8.5A3.75 3.75 0 0 0 7.75 20h8.5A3.75 3.75 0 0 0 20 16.25v-8.5A3.75 3.75 0 0 0 16.25 4h-8.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm5.25-2.55a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4Z",
  },
  {
    label: "Facebook",
    href: SOCIAL_LINKS.facebook,
    viewBox: "0 0 24 24",
    path: "M14.2 8.4V6.65c0-.84.2-1.25 1.36-1.25H17V2.16C16.3 2.06 15.62 2 14.94 2c-3.02 0-5.08 1.84-5.08 5.23V8.4H6.5v3.65h3.36V22h4.34v-9.95h3.34l.5-3.65H14.2Z",
  },
  {
    label: "TikTok",
    href: SOCIAL_LINKS.tiktok,
    viewBox: "0 0 24 24",
    path: "M16.62 2c.35 2.76 1.9 4.4 4.38 4.58v3.17a7.56 7.56 0 0 1-4.3-1.34v6.5c0 4.42-2.58 7.09-6.55 7.09C6.73 22 4 19.5 4 16.32c0-3.63 3.06-6.28 7.02-5.8v3.39c-1.9-.28-3.42.67-3.42 2.32 0 1.42 1.15 2.39 2.6 2.39 1.69 0 2.72-1.02 2.72-3.45V2h3.7Z",
  },
  {
    label: "LinkedIn",
    href: SOCIAL_LINKS.linkedin,
    viewBox: "0 0 24 24",
    path: "M6.94 8.98H3.2V21h3.74V8.98ZM5.07 3C3.86 3 3 3.8 3 4.86c0 1.03.83 1.86 2.02 1.86h.03c1.24 0 2.02-.83 2.02-1.86C7.04 3.8 6.29 3 5.07 3ZM21 14.1c0-3.66-1.95-5.36-4.56-5.36-2.1 0-3.04 1.15-3.56 1.96V8.98H9.14c.05 1.13 0 12.02 0 12.02h3.74v-6.71c0-.36.03-.72.13-.98.27-.72.9-1.47 1.95-1.47 1.38 0 1.93 1.05 1.93 2.59V21H21v-6.9Z",
  },
  {
    label: "WhatsApp",
    href: WHATSAPP_URL,
    viewBox: "0 0 24 24",
    path: "M12 2C6.48 2 2 6.48 2 12c0 1.77.46 3.44 1.27 4.89L2 22l5.25-1.27A9.94 9.94 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2Zm5.25 14.19c-.21.59-1.23 1.12-1.72 1.17-.44.04-.99.06-1.59-.1-.37-.12-.84-.27-1.44-.53-2.54-1.1-4.2-3.66-4.33-3.83-.12-.17-1.04-1.38-1.04-2.64 0-1.25.66-1.87.89-2.13.23-.25.5-.31.67-.31h.48c.15 0 .35-.06.55.42.21.49.71 1.69.77 1.81.06.12.1.27.02.43-.08.17-.12.27-.23.42-.12.15-.25.33-.36.44-.12.12-.24.25-.1.49s.6 1.02 1.3 1.64c.89.8 1.64 1.04 1.88 1.16.25.12.39.1.53-.06.15-.17.62-.73.78-.98.17-.25.33-.21.55-.12.23.08 1.44.68 1.69.8.25.12.41.18.47.28.06.1.06.59-.15 1.18Z",
  },
] as const;
---

<footer class="border-t-[1.5px] border-ink bg-paper text-ink">
  <div class="container-shell py-16 md:py-20">
    <div
      class="grid gap-10 border-b-[1.5px] border-ink pb-12 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr]"
    >
      <div>
        <Logo class="mb-4 text-[2rem]" />
        <p class="max-w-sm text-sm leading-6 text-gray-700">
          Agencia de marketing para MYPEs peruanas. Webs, marca y campañas que
          traen clientes reales, rápido.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {
            socialItems.map((item) => (
              <a
                href={item.href}
                class="focus-ring grid size-10 place-items-center rounded-full border-[1.5px] border-ink transition hover:border-orange hover:bg-orange hover:text-paper"
                aria-label={item.label}
                title={item.label}
                target="_blank"
                rel="noreferrer"
              >
                <svg
                  viewBox={item.viewBox}
                  class="size-5"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={item.path} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <h2
          class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange"
        >
          Servicios
        </h2>
        <ul class="space-y-2.5">
          {
            FOOTER_NAVIGATION.services.map((item) => (
              <li>
                <a
                  class="focus-ring rounded text-sm text-gray-700 hover:text-ink"
                  href={item.href}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2
          class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange"
        >
          Agencia
        </h2>
        <ul class="space-y-2.5">
          {
            FOOTER_NAVIGATION.agency.map((item) => (
              <li>
                <a
                  class="focus-ring rounded text-sm text-gray-700 hover:text-ink"
                  href={item.href}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h2
          class="mb-4 font-display text-sm font-semibold uppercase tracking-[0.08em] text-orange"
        >
          Contacto
        </h2>
        <ul class="space-y-2.5 text-sm text-gray-700">
          <li>
            <a
              class="focus-ring rounded hover:text-ink"
              href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
          </li>
          <li>
            <a
              class="focus-ring rounded hover:text-ink"
              href={`tel:${CONTACT_PHONE.replace(/[^\d+]/g, "")}`}
              >{CONTACT_PHONE}</a>
          </li>
          <li>{BUSINESS_LOCATION}</li>
          <li>{BUSINESS_HOURS}</li>
        </ul>
      </div>
    </div>

    <div
      class="flex flex-wrap items-center justify-between gap-4 pt-8 text-sm text-gray-500"
    >
      <p>© {CURRENT_YEAR} {LEGAL_NAME} · Hecho con {BRAND_NAME} en Huancayo</p>
      <div class="flex flex-wrap gap-5">
        {
          FOOTER_NAVIGATION.legal.map((item) => (
            <a class="focus-ring rounded hover:text-ink" href={item.href}>
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
