---
import { typeRows } from "@config";
---

<section id="typography" class="border-t-[1.5px] border-ink bg-paper-warm py-20 md:py-24">
  <div class="container-shell">
    <div class="mb-12 flex flex-wrap items-end justify-between gap-6">
      <div>
        <p class="font-display text-lg font-semibold uppercase tracking-[0.1em] text-orange">03 / Tipografía</p>
        <h2 class="mt-2 font-display text-[clamp(2.5rem,5vw,4rem)] font-semibold leading-none tracking-normal">Fredoka + Jakarta.</h2>
      </div>
      <p class="max-w-md leading-7 text-gray-700">
        <strong>Fredoka</strong> para titulares — redonda, amigable, con la misma personalidad del logo. <strong>Plus Jakarta Sans</strong> para textos largos — legible, moderna, y gratis en Google Fonts.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <article class="brand-outline rounded-brand-lg bg-paper p-8">
        <div class="font-display text-[7rem] font-semibold leading-none tracking-normal">Aa</div>
        <h3 class="mt-4 font-display text-2xl font-semibold tracking-normal">Fredoka</h3>
        <p class="mt-1 text-sm text-gray-700">Display · Titulares · Logo · Botones clave</p>
        <p class="mt-3 text-sm text-gray-500">Regular 400 · Medium 500 · SemiBold 600 · Bold 700</p>
      </article>
      <article class="brand-outline rounded-brand-lg bg-paper p-8">
        <div class="font-body text-[7rem] font-bold leading-none tracking-normal">Aa</div>
        <h3 class="mt-4 font-display text-2xl font-semibold tracking-normal">Plus Jakarta Sans</h3>
        <p class="mt-1 text-sm text-gray-700">Texto corrido · UI · Formularios · Listas</p>
        <p class="mt-3 text-sm text-gray-500">Regular 400 · Medium 500 · SemiBold 600 · Bold 700 · ExtraBold 800</p>
      </article>
    </div>

    <div class="mt-12">
      {
        typeRows.map((row) => (
          <div class="grid gap-3 border-b border-dashed border-gray-300 py-6 md:grid-cols-[180px_1fr] md:items-baseline">
            <div class="text-sm font-semibold text-gray-700">{row.tag}</div>
            <div class:list={["font-display tracking-normal", row.className]}>{row.sample}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
