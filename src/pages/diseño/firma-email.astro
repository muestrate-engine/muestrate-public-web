---
import { BaseLayout } from "@layouts";
import {
  DeliverablePageHeader,
  DesignFooter,
  DesignHeader,
  EmailSignatureShowcase,
} from "@components";
import { PAGE_META } from "@config";
---

<BaseLayout meta={PAGE_META.designEmailSignature}>
  <DesignHeader />
  <main>
    <DeliverablePageHeader
      label="Entregable 03"
      title="Firma de email"
      description="Tres variantes para distintos contextos: horizontal para uso diario, card oscura para propuestas y ventas, y minimal para respuestas rápidas. Compatible con Gmail, Outlook y Apple Mail."
    />
    <EmailSignatureShowcase />
  </main>
  <DesignFooter />
</BaseLayout>
